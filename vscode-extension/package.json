{
  "name": "claude-code-reviewer",
  "displayName": "Claude Code Reviewer",
  "description": "AI code review for GitHub PRs and GitLab MRs powered by Claude — auto-posts inline comments with critical and informational findings",
  "version": "0.2.1",
  "publisher": "shubhesh07",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shubhesh07/claude-code-reviewer"
  },
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Linters", "Other"],
  "keywords": ["code review", "claude", "AI review", "pull request", "merge request"],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claude-reviewer.reviewCurrentPr",
        "title": "Claude: Review Current PR"
      },
      {
        "command": "claude-reviewer.reviewByUrl",
        "title": "Claude: Review PR by URL"
      }
    ],
    "configuration": {
      "title": "Claude Code Reviewer",
      "properties": {
        "claude-reviewer.reviewShPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to review.sh. Leave empty to auto-detect."
        },
        "claude-reviewer.platform": {
          "type": "string",
          "enum": ["auto", "github", "gitlab"],
          "default": "auto",
          "description": "Platform for PR/MR detection. 'auto' detects from available CLIs."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}
