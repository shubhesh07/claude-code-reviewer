# claude-code-reviewer configuration
# Copy this file to config.env and edit as needed:
#   cp config.example.env config.env

# Platform: auto | github | gitlab
# "auto" detects from available CLIs (gh / glab)
PLATFORM=auto

# Your username (auto-detected if empty)
USERNAME=

# Poll interval in seconds (default: 900 = 15 minutes)
POLL_INTERVAL=900

# Claude model (empty = default, or: sonnet, haiku, opus)
CLAUDE_MODEL=

# Review tool: gstack (default) or builtin
# gstack  — Two-pass review (CRITICAL + INFORMATIONAL), clones repo for full context
#            Based on github.com/garrytan/gstack review methodology
# builtin — Diff-only review, no clone needed (lighter, faster)
REVIEW_TOOL=gstack

# Which role to check for your PRs/MRs
# reviewer  — PRs/MRs where you're requested as reviewer (default)
# assignee  — PRs/MRs assigned to you
# author    — PRs/MRs you authored (self-review)
REVIEW_ROLE=reviewer

# Greptile bot comment triage (GitHub only)
# true  — Fetch and classify Greptile bot comments, reply to false positives
# false — Skip Greptile integration
GREPTILE_TRIAGE=true

# Skip PRs/MRs with more changed files than this
MAX_FILES=100

# Max PRs/MRs to review per poll cycle
MAX_PRS_PER_RUN=10

# Auto-trim log file to this many lines
LOG_MAX_LINES=5000
